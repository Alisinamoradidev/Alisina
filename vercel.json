{
  "functions": {
    "api/handler.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/property/(.*)", "destination": "/api/handler" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/404.html" }
  ]
}
