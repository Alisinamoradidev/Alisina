{
  "functions": {
    "api/handler.js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/@tensorflow/tfjs-backend-wasm/dist/tfjs-backend-wasm-threaded-simd.wasm"
    }
  },
  "routes": [
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/property/(.*)", "destination": "/api/handler" },
    { "source": "/blog/(.*)", "destination": "/api/handler" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/404.html" }
  ]
}
